model User {
    id           String       @id @default(uuid())
    name         String       @db.VarChar(255)
    email        String       @unique
    password     String
    activeStatus ActiveStatus @default(ACTIVE)
    role         Role         @default(USER)
    profile      Profile?
    post         Post[]
    comment      Comment[]
    subscription Subscription?
    createdAt    DateTime     @default(now())
    updateAt     DateTime     @updatedAt

    @@map("users")
}
